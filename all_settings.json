    "choose_section_details": "\u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09df \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf\u09a4\u09c7 \u0986\u09ae\u09b0\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u098f\u09ae\u09a8 \u09b9\u0993\u09df\u09be \u0989\u099a\u09bf\u09a4 \u09af\u09be \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u09b8\u0995\u09cd\u09b7\u09ae \u0995\u09b0\u09c7, \u0985\u09a4\u09bf\u09b0\u09bf\u0995\u09cd\u09a4 \u099a\u09be\u09aa \u09b8\u09c3\u09b7\u09cd\u099f\u09bf \u0995\u09b0\u09c7 \u09a8\u09be\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u09b9\u09b2\u09cb \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09bf \u09a1\u09bf\u099c\u09bf\u099f\u09be\u09b2 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09be \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0, \u099a\u09be\u0995\u09b0\u09bf\u09aa\u09cd\u09b0\u09be\u09b0\u09cd\u09a5\u09c0 \u098f\u09ac\u0982 \u09aa\u09c7\u09b6\u09be\u099c\u09c0\u09ac\u09c0\u09b0\u09be \u09a8\u09bf\u09df\u09ae\u09bf\u09a4\u09ad\u09be\u09ac\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0 \u099c\u09cd\u099e\u09be\u09a8 \u0993 \u09a6\u0995\u09cd\u09b7\u09a4\u09be \u0989\u09a8\u09cd\u09a8\u09a4 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964\r\n\r\n\u0987\u09a8\u09cd\u099f\u09be\u09b0\u09c7\u0995\u09cd\u099f\u09bf\u09ad \u09b2\u09c7\u09b8\u09a8, \u09b2\u09be\u0987\u09ad \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be \u098f\u09ac\u0982 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09a7\u09b0\u09cd\u09ae\u09c0 \u09b6\u09c7\u0996\u09be\u09b0 \u0985\u09ad\u09bf\u099c\u09cd\u099e\u09a4\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09df \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf \u09b8\u09ac\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09b6\u09c7\u0996\u09be\u0995\u09c7 \u0986\u09b0\u0993 \u09b8\u09b9\u099c, \u0995\u09be\u09b0\u09cd\u09af\u0995\u09b0 \u098f\u09ac\u0982 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09bf\u0995 \u0995\u09b0\u09c7 \u09a4\u09c1\u09b2\u09a4\u09c7 \u0995\u09be\u099c \u0995\u09b0\u099b\u09c7\u0964\r\n",
